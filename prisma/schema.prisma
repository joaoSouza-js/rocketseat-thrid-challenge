generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum PetSize {
  SMALL
  MEDIUM
  LARGE
}

enum PetDependence {
  LOW
  MEDIUM
  HIGH
}

enum PetEnergy {
  LOW
  MEDIUM
  HIGH
}

model Org {
  id          String   @id
  name        String
  email       String   @unique
  phone       String
  description String
  createdAt   DateTime @default(now())

  pets Pet[]

  @@map("orgs")
}

model Pet {
  id         String        @id
  name       String
  orgId      String
  state      String
  city       String
  size       PetSize
  dependence PetDependence
  energy     PetEnergy
  createdAt  DateTime      @default(now())

  org Org @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
  @@index([state, city])
  @@map("pets")
}
